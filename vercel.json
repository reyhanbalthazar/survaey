{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/fe-survey-app/browser",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.csr.html"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/index.csr.html"
    }
  ]
}
